{
  "manifest_version": 3,
  "name": "PSDify Helper",
  "version": "0.1.0",
  "description": "Copy Connect-Dify login commands or session tokens from any Dify console page. Works with cloud.dify.ai and self-hosted instances.",
  "permissions": [
    "cookies",
    "contextMenus",
    "clipboardWrite",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://cloud.dify.ai/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
